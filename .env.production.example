# ─── App ───
NODE_ENV=production
PORT=3000

# ─── Web URL (CORS origin, comma-separated for multiple) ───
WEB_URL=https://nextoffice.cnppai.com

# ─── Public API URL (used at build-time by Next.js, leave empty for same-origin via nginx) ───
PUBLIC_API_URL=

# ─── Database (MariaDB on host 192.168.1.4) ───
# deploy.sh ตัดเครื่องหมายคำพูดรอบค่าอัตโนมัติ — ใส่หรือไม่ใส่ quote ก็ได้
DATABASE_URL=mysql://root:YOUR_DB_PASSWORD@192.168.1.4:3306/nextoffice_db
# Optional: export before ./deploy.sh so step [4/7] can CREATE DATABASE (see deploy.sh)
# MYSQL_ROOT_PASSWORD=YOUR_DB_PASSWORD

# ─── Redis (internal Docker service) ───
REDIS_HOST=redis
REDIS_PORT=6379

# ─── MinIO (internal Docker service) ───
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_in_production
MINIO_BUCKET=nextoffice

# ─── LINE Messaging API ───
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# ─── LINE MINI App (LIFF) ───
# Separate LINE Login channel in the same Provider as the Messaging API above.
# LINE_LOGIN_CHANNEL_ID is used server-side to verify LIFF access token audience.
# LIFF_ID is read at runtime by a Server Component and passed to the client
# (same pattern as GOOGLE_CLIENT_ID — avoids baking into the build).
LINE_LOGIN_CHANNEL_ID=your_line_login_channel_id
LIFF_ID=your_liff_id_here

# ─── Google AI (Gemini) ───
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── Google Calendar ───
# Uses same OAuth credentials as Google Drive (add calendar scope when authorizing)
GOOGLE_CALENDAR_ID=primary

# ─── JWT ───
JWT_SECRET=change_me_to_random_64_char_string
JWT_EXPIRES_IN=7d
