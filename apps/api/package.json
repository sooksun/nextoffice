{
  "name": "@nextoffice/api",
  "version": "0.0.1",
  "description": "AI E-office API",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "seed:admin": "node -r dotenv/config dist/prisma/seed-admin.js",
    "seed:sarabun": "node -r dotenv/config dist/prisma/seed-sarabun.js",
    "seed:school": "npx ts-node prisma/seed-school.ts",
    "seed:all": "npm run seed:admin && npm run seed:sarabun && npm run seed:school"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/main.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@shared/(.*)$": "<rootDir>/../../packages/shared-types/src/$1"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "@nestjs/bull": "^10.2.3",
    "@nestjs/common": "^10.4.22",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.22",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.4.2",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/adapter-mariadb": "^7.6.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@qdrant/js-client-rest": "^1.17.0",
    "@types/pg": "^8.20.0",
    "axios": "^1.14.0",
    "bull": "^4.16.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.2",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "mysql2": "^3.15.3",
    "nodemailer": "^8.0.5",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^2.16.105",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "wordcut": "^0.9.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.22",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
