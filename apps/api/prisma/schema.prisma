generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────────────────────
// PHASE 1: Core / Organizations
// ─────────────────────────────────────────────

model Organization {
  id                    BigInt   @id @default(autoincrement())
  name                  String   @db.VarChar(255)
  shortName             String?  @map("short_name") @db.VarChar(100)
  orgCode               String?  @map("org_code") @db.VarChar(50)
  orgType               String   @map("org_type") @db.VarChar(50) @default("school") // school | area_office | central_office
  address               String?  @db.Text
  province              String?  @db.VarChar(100)
  district              String?  @db.VarChar(100)          // อำเภอ/เขต (geography)
  areaCode              String?  @map("area_code") @db.VarChar(100)  // เขตพื้นที่การศึกษา เช่น "สพป.เชียงราย เขต 3"
  phone                 String?  @db.VarChar(20)
  email                 String?  @db.VarChar(255)
  website               String?  @db.VarChar(255)
  parentOrganizationId  BigInt?  @map("parent_organization_id") // สำหรับ school → area_office hierarchy
  activeAcademicYearId  BigInt?  @map("active_academic_year_id") // ปีสารบรรณที่ใช้งานอยู่
  refLatitude           Float?   @map("ref_latitude")
  refLongitude          Float?   @map("ref_longitude")
  geofenceRadius        Int      @map("geofence_radius") @default(200) // meters
  isActive              Boolean  @map("is_active") @default(true)
  createdAt             DateTime @map("created_at") @default(now())
  updatedAt             DateTime @map("updated_at") @updatedAt

  parentOrganization   Organization?  @relation("OrgHierarchy", fields: [parentOrganizationId], references: [id])
  childOrganizations   Organization[] @relation("OrgHierarchy")
  activeAcademicYear   AcademicYear?  @relation("OrgActiveYear", fields: [activeAcademicYearId], references: [id])
  profiles             OrganizationProfile[]
  contextScores        OrganizationContextScore[]
  lineUsers            LineUser[]
  users                User[]
  inboundCases         InboundCase[]
  documentIntakes      DocumentIntake[]
  budgets              Budget[]
  routingsFrom         DocumentRouting[] @relation("RoutingFrom")
  routingsTo           DocumentRouting[] @relation("RoutingTo")
  workGroups           WorkGroup[]
  staffAssignments     StaffAssignment[]
  outboundDocuments    OutboundDocument[]
  documentRegistries   DocumentRegistry[]
  registrationCounters RegistrationCounter[]
  projects             Project[]
  faceRegistrations    FaceRegistration[]
  attendanceRecords    AttendanceRecord[]
  leaveRequests        LeaveRequest[]
  travelRequests       TravelRequest[]
  approvalChains       ApprovalChainConfig[]
  knowledgeItems       UserKnowledgeItem[]

  @@index([parentOrganizationId])
  @@map("organizations")
}

model OrganizationProfile {
  id                  BigInt   @id @default(autoincrement())
  organizationId      BigInt   @map("organization_id")
  profileYear         Int      @map("profile_year")
  schoolSize          String?  @map("school_size") @db.VarChar(20)
  studentCount        Int?     @map("student_count")
  teacherCount        Int?     @map("teacher_count")
  classroomCount      Int?     @map("classroom_count")
  internetQuality     String?  @map("internet_quality") @db.VarChar(20)
  budgetLevel         String?  @map("budget_level") @db.VarChar(20)
  geographyType       String?  @map("geography_type") @db.VarChar(30)
  socioeconomicLevel  String?  @map("socioeconomic_level") @db.VarChar(20)
  languageContext     String?  @map("language_context") @db.VarChar(50)
  specialConstraints  String?  @map("special_constraints") @db.Text
  strategicStrengths  String?  @map("strategic_strengths") @db.Text
  createdAt           DateTime @map("created_at") @default(now())
  updatedAt           DateTime @map("updated_at") @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("organization_profiles")
}

model ContextDimension {
  id              BigInt   @id @default(autoincrement())
  dimensionCode   String   @map("dimension_code") @db.VarChar(50) @unique
  dimensionName   String   @map("dimension_name") @db.VarChar(255)
  description     String?  @db.Text
  scaleMin        Float    @map("scale_min") @default(1)
  scaleMax        Float    @map("scale_max") @default(5)
  createdAt       DateTime @map("created_at") @default(now())

  contextScores OrganizationContextScore[]

  @@map("context_dimensions")
}

model OrganizationContextScore {
  id              BigInt   @id @default(autoincrement())
  organizationId  BigInt   @map("organization_id")
  dimensionId     BigInt   @map("dimension_id")
  score           Float
  level           String?  @db.VarChar(20)
  note            String?  @db.Text
  scoredAt        DateTime @map("scored_at") @default(now())

  organization Organization     @relation(fields: [organizationId], references: [id])
  dimension    ContextDimension @relation(fields: [dimensionId], references: [id])

  @@map("organization_context_scores")
}

model Topic {
  id            BigInt   @id @default(autoincrement())
  topicCode     String   @map("topic_code") @db.VarChar(50) @unique
  topicNameTh   String   @map("topic_name_th") @db.VarChar(255)
  topicNameEn   String?  @map("topic_name_en") @db.VarChar(255)
  parentTopicId BigInt?  @map("parent_topic_id")
  level         Int      @default(1)
  description   String?  @db.Text
  isActive      Boolean  @map("is_active") @default(true)
  createdAt     DateTime @map("created_at") @default(now())

  parentTopic    Topic?  @relation("TopicHierarchy", fields: [parentTopicId], references: [id])
  childTopics    Topic[] @relation("TopicHierarchy")
  documentTopics DocumentTopic[]
  caseTopics     CaseTopic[]
  horizonTopics  HorizonItemTopic[]
  policyTopics   PolicyClauseTopic[]

  @@map("topics")
}

// ─────────────────────────────────────────────
// PHASE 1: Documents
// ─────────────────────────────────────────────

model Document {
  id               BigInt    @id @default(autoincrement())
  documentCode     String?   @map("document_code") @db.VarChar(100)
  title            String    @db.VarChar(500)
  sourceType       String    @map("source_type") @db.VarChar(50)
  documentType     String    @map("document_type") @db.VarChar(50)
  sourceChannel    String?   @map("source_channel") @db.VarChar(50)
  issuingAuthority String?   @map("issuing_authority") @db.VarChar(255)
  sourceUrl        String?   @map("source_url") @db.VarChar(1000)
  language         String?   @db.VarChar(10) @default("th")
  jurisdiction     String?   @db.VarChar(50)
  publishedAt      DateTime? @map("published_at")
  effectiveDate    DateTime? @map("effective_date")
  expiryDate       DateTime? @map("expiry_date")
  status           String    @db.VarChar(30) @default("active")
  trustLevel       Float?    @map("trust_level")
  freshnessScore   Float?    @map("freshness_score")
  summaryText      String?   @map("summary_text") @db.Text
  fullText         String?   @map("full_text") @db.LongText
  storagePath      String?   @map("storage_path") @db.VarChar(500)
  createdAt        DateTime  @map("created_at") @default(now())
  updatedAt        DateTime  @map("updated_at") @updatedAt

  documentTopics  DocumentTopic[]
  documentChunks  DocumentChunk[]
  horizonItems    HorizonItem[]
  policyItems     PolicyItem[]
  inboundCases    InboundCase[]

  @@index([sourceType])
  @@index([documentType])
  @@index([publishedAt])
  @@map("documents")
}

model DocumentTopic {
  id             BigInt  @id @default(autoincrement())
  documentId     BigInt  @map("document_id")
  topicId        BigInt  @map("topic_id")
  relevanceScore Float?  @map("relevance_score")

  document Document @relation(fields: [documentId], references: [id])
  topic    Topic    @relation(fields: [topicId], references: [id])

  @@index([documentId])
  @@index([topicId])
  @@map("document_topics")
}

model DocumentChunk {
  id            BigInt   @id @default(autoincrement())
  documentId    BigInt   @map("document_id")
  chunkIndex    Int      @map("chunk_index")
  chunkText     String   @map("chunk_text") @db.Text
  tokenCount    Int?     @map("token_count")
  pageNo        Int?     @map("page_no")
  sectionTitle  String?  @map("section_title") @db.VarChar(255)
  semanticLabel String?   @map("semantic_label") @db.VarChar(100)
  embeddingId   String?   @map("embedding_id") @db.VarChar(100)
  qdrantPointId String?   @map("qdrant_point_id") @db.VarChar(36)
  embeddingModel String?  @map("embedding_model") @db.VarChar(50)
  embeddedAt    DateTime? @map("embedded_at")
  createdAt     DateTime  @map("created_at") @default(now())

  document Document @relation(fields: [documentId], references: [id])

  @@index([documentId])
  @@map("document_chunks")
}

// ─────────────────────────────────────────────
// PHASE 2: Horizon RAG
// ─────────────────────────────────────────────

model HorizonItem {
  id                  BigInt   @id @default(autoincrement())
  documentId          BigInt   @map("document_id")
  itemType            String   @map("item_type") @db.VarChar(50)
  scope               String?  @db.VarChar(50)
  countryCode         String?  @map("country_code") @db.VarChar(10)
  sector              String?  @db.VarChar(50)
  implementationStage String?  @map("implementation_stage") @db.VarChar(30)
  evidenceStrength    String?  @map("evidence_strength") @db.VarChar(20)
  budgetRequirement   String?  @map("budget_requirement") @db.VarChar(20)
  techRequirement     String?  @map("tech_requirement") @db.VarChar(20)
  scalability         String?  @db.VarChar(20)
  summary             String?  @db.Text
  createdAt           DateTime @map("created_at") @default(now())
  updatedAt           DateTime @map("updated_at") @updatedAt

  document        Document               @relation(fields: [documentId], references: [id])
  practices       HorizonPractice[]
  topics          HorizonItemTopic[]
  contextFitRules HorizonContextFitRule[]

  @@map("horizon_items")
}

model HorizonItemTopic {
  id            BigInt @id @default(autoincrement())
  horizonItemId BigInt @map("horizon_item_id")
  topicId       BigInt @map("topic_id")
  relevance     Float? @default(1.0)

  horizonItem HorizonItem @relation(fields: [horizonItemId], references: [id])
  topic       Topic       @relation(fields: [topicId], references: [id])

  @@map("horizon_item_topics")
}

model HorizonPractice {
  id                   BigInt   @id @default(autoincrement())
  horizonItemId        BigInt   @map("horizon_item_id")
  practiceTitle        String   @map("practice_title") @db.VarChar(500)
  problemAddressed     String?  @map("problem_addressed") @db.Text
  targetGroup          String?  @map("target_group") @db.VarChar(255)
  implementationMethod String?  @map("implementation_method") @db.Text
  requiredCapabilities String?  @map("required_capabilities") @db.Text
  expectedOutcomes     String?  @map("expected_outcomes") @db.Text
  createdAt            DateTime @map("created_at") @default(now())
  updatedAt            DateTime @map("updated_at") @updatedAt

  horizonItem     HorizonItem            @relation(fields: [horizonItemId], references: [id])
  contextFitRules HorizonContextFitRule[]

  @@map("horizon_practices")
}

model HorizonContextFitRule {
  id            BigInt  @id @default(autoincrement())
  horizonItemId BigInt  @map("horizon_item_id")
  practiceId    BigInt? @map("practice_id")
  dimensionId   BigInt  @map("dimension_id")
  minScore      Float   @map("min_score") @default(1)
  maxScore      Float   @map("max_score") @default(5)
  fitNote       String? @map("fit_note") @db.Text

  horizonItem HorizonItem      @relation(fields: [horizonItemId], references: [id])
  practice    HorizonPractice? @relation(fields: [practiceId], references: [id])

  @@map("horizon_context_fit_rules")
}

// ─────────────────────────────────────────────
// PHASE 2: Policy RAG
// ─────────────────────────────────────────────

model PolicyItem {
  id                  BigInt   @id @default(autoincrement())
  documentId          BigInt   @map("document_id")
  policyType          String   @map("policy_type") @db.VarChar(50)
  issuingAuthority    String?  @map("issuing_authority") @db.VarChar(255)
  jurisdictionLevel   String?  @map("jurisdiction_level") @db.VarChar(30)
  policyNumber        String?  @map("policy_number") @db.VarChar(100)
  effectiveStatus     String   @map("effective_status") @db.VarChar(30) @default("active")
  supersedesPolicyId  BigInt?  @map("supersedes_policy_id")
  mandatoryLevel      String?  @map("mandatory_level") @db.VarChar(20)
  complianceRiskLevel String?  @map("compliance_risk_level") @db.VarChar(20)
  summaryForAction    String?  @map("summary_for_action") @db.Text
  createdAt           DateTime @map("created_at") @default(now())
  updatedAt           DateTime @map("updated_at") @updatedAt

  document Document      @relation(fields: [documentId], references: [id])
  clauses  PolicyClause[]

  @@map("policy_items")
}

model PolicyClause {
  id                BigInt   @id @default(autoincrement())
  policyItemId      BigInt   @map("policy_item_id")
  clauseCode        String   @map("clause_code") @db.VarChar(50)
  clauseText        String   @map("clause_text") @db.Text
  obligationType    String?  @map("obligation_type") @db.VarChar(30)
  actionRequired    String?  @map("action_required") @db.VarChar(100)
  responsibleRole   String?  @map("responsible_role") @db.VarChar(100)
  applicableContext String?  @map("applicable_context") @db.VarChar(100)
  triggerCondition  String?  @map("trigger_condition") @db.Text
  penaltyIfIgnored  String?  @map("penalty_if_ignored") @db.Text
  remediationNote   String?  @map("remediation_note") @db.Text
  createdAt         DateTime @map("created_at") @default(now())
  updatedAt         DateTime @map("updated_at") @updatedAt

  policyItem         PolicyItem               @relation(fields: [policyItemId], references: [id])
  topics             PolicyClauseTopic[]
  applicabilityRules PolicyApplicabilityRule[]

  @@map("policy_clauses")
}

model PolicyClauseTopic {
  id       BigInt @id @default(autoincrement())
  clauseId BigInt @map("clause_id")
  topicId  BigInt @map("topic_id")
  relevance Float? @default(1.0)

  clause PolicyClause @relation(fields: [clauseId], references: [id])
  topic  Topic        @relation(fields: [topicId], references: [id])

  @@map("policy_clause_topics")
}

model PolicyApplicabilityRule {
  id              BigInt  @id @default(autoincrement())
  clauseId        BigInt  @map("clause_id")
  orgType         String? @map("org_type") @db.VarChar(50)
  dimensionId     BigInt? @map("dimension_id")
  minScore        Float?  @map("min_score")
  maxScore        Float?  @map("max_score")
  condition       String? @db.Text
  recommendedNote String? @map("recommended_note") @db.Text

  clause PolicyClause @relation(fields: [clauseId], references: [id])

  @@map("policy_applicability_rules")
}

// ─────────────────────────────────────────────
// PHASE 3: RAG & Case Management
// ─────────────────────────────────────────────

model InboundCase {
  id                    BigInt    @id @default(autoincrement())
  organizationId        BigInt    @map("organization_id")
  academicYearId        BigInt?   @map("academic_year_id")
  title                 String    @db.VarChar(255)
  description           String?   @db.LongText
  sourceDocumentId      BigInt?   @map("source_document_id")
  receivedAt            DateTime  @map("received_at") @default(now())
  dueDate               DateTime? @map("due_date")
  status                String    @db.VarChar(50) @default("new") // new → registered → assigned → in_progress → completed → archived
  // ─── Workflow fields ───
  registrationNo        String?   @map("registration_no") @db.VarChar(50) // เลขรับ เช่น "001/2568"
  registeredAt          DateTime? @map("registered_at")
  registeredByUserId    BigInt?   @map("registered_by_user_id")
  assignedToUserId      BigInt?   @map("assigned_to_user_id") // ผู้รับผิดชอบหลัก
  selectedOptionId      BigInt?   @map("selected_option_id") // option A/B/C ที่เลือก
  urgencyLevel          String    @map("urgency_level") @db.VarChar(20) @default("normal") // normal | urgent | very_urgent | most_urgent
  securityLevel         String    @map("security_level") @db.VarChar(20) @default("normal") // normal | confidential | secret
  directorNote          String?   @map("director_note") @db.Text // คำสั่ง ผอ.
  googleCalendarEventId  String?   @map("google_calendar_event_id") @db.VarChar(255)
  meetingCalendarEventId String?   @map("meeting_calendar_event_id") @db.VarChar(255)
  createdAt              DateTime  @map("created_at") @default(now())
  updatedAt              DateTime  @map("updated_at") @updatedAt

  organization       Organization          @relation(fields: [organizationId], references: [id])
  academicYear       AcademicYear?         @relation(fields: [academicYearId], references: [id])
  sourceDocument     Document?             @relation(fields: [sourceDocumentId], references: [id])
  registeredBy       User?                 @relation("CaseRegisteredBy", fields: [registeredByUserId], references: [id])
  assignedTo         User?                 @relation("CaseAssignedTo", fields: [assignedToUserId], references: [id])
  topics             CaseTopic[]
  retrievals         CaseRetrievalResult[]
  options            CaseOption[]
  assignments        CaseAssignment[]
  activities         CaseActivity[]
  outboundDocuments  OutboundDocument[]
  documentRegistries DocumentRegistry[]
  predictions        CasePrediction[]

  @@index([academicYearId])
  @@index([status])
  @@index([registeredByUserId])
  @@index([assignedToUserId])
  @@map("inbound_cases")
}


model CaseTopic {
  id            BigInt  @id @default(autoincrement())
  inboundCaseId BigInt  @map("inbound_case_id")
  topicId       BigInt  @map("topic_id")
  relevanceScore Float?  @map("relevance_score")

  inboundCase InboundCase @relation(fields: [inboundCaseId], references: [id])
  topic       Topic       @relation(fields: [topicId], references: [id])

  @@index([inboundCaseId])
  @@map("case_topics")
}

model CaseRetrievalResult {
  id              BigInt   @id @default(autoincrement())
  inboundCaseId   BigInt   @map("inbound_case_id")
  sourceType      String   @map("source_type") @db.VarChar(50)
  sourceRecordId  BigInt   @map("source_record_id")
  retrievalRank   Int      @map("retrieval_rank") @default(1)
  semanticScore   Float?   @map("semantic_score")
  trustScore      Float?   @map("trust_score")
  freshnessScore  Float?   @map("freshness_score")
  contextFitScore Float?   @map("context_fit_score")
  finalScore      Float?   @map("final_score")
  rationale       String?  @db.Text
  createdAt       DateTime @map("created_at") @default(now())

  inboundCase InboundCase @relation(fields: [inboundCaseId], references: [id])

  @@index([inboundCaseId])
  @@map("case_retrieval_results")
}

model CaseOption {
  id                   BigInt   @id @default(autoincrement())
  inboundCaseId        BigInt   @map("inbound_case_id")
  optionCode           String   @map("option_code") @db.VarChar(5)
  title                String   @db.VarChar(500)
  description          String?  @db.LongText
  implementationSteps  String?  @map("implementation_steps") @db.Text
  expectedBenefits     String?  @map("expected_benefits") @db.Text
  risks                String?  @db.Text
  policyComplianceNote String?  @map("policy_compliance_note") @db.Text
  contextFitNote       String?  @map("context_fit_note") @db.Text
  feasibilityScore     Float?   @map("feasibility_score")
  innovationScore      Float?   @map("innovation_score")
  complianceScore      Float?   @map("compliance_score")
  overallScore         Float?   @map("overall_score")
  createdAt            DateTime @map("created_at") @default(now())
  updatedAt            DateTime @map("updated_at") @updatedAt

  inboundCase InboundCase           @relation(fields: [inboundCaseId], references: [id])
  references  CaseOptionReference[]

  @@index([inboundCaseId])
  @@map("case_options")
}

model CaseOptionReference {
  id               BigInt  @id @default(autoincrement())
  caseOptionId     BigInt  @map("case_option_id")
  referenceType    String  @map("reference_type") @db.VarChar(50)
  sourceRecordId   BigInt  @map("source_record_id")
  citationText     String? @map("citation_text") @db.Text
  contributionNote String? @map("contribution_note") @db.Text

  caseOption CaseOption @relation(fields: [caseOptionId], references: [id])

  @@map("case_option_references")
}

// ─────────────────────────────────────────────
// LINE Integration
// ─────────────────────────────────────────────

model LineChannel {
  id                     BigInt   @id @default(autoincrement())
  channelName            String   @map("channel_name") @db.VarChar(100)
  lineChannelId          String   @map("line_channel_id") @db.VarChar(100)
  lineChannelSecret      String   @map("line_channel_secret") @db.VarChar(255)
  lineChannelAccessToken String   @map("line_channel_access_token") @db.Text
  isActive               Boolean  @map("is_active") @default(true)
  createdAt              DateTime @map("created_at") @default(now())
  updatedAt              DateTime @map("updated_at") @updatedAt

  lineUsers  LineUser[]
  lineEvents LineEvent[]

  @@map("line_channels")
}

model LineUser {
  id             BigInt   @id @default(autoincrement())
  lineChannelId  BigInt   @map("line_channel_id")
  lineUserId     String   @map("line_user_id") @db.VarChar(100) @unique
  displayName    String?  @map("display_name") @db.VarChar(255)
  pictureUrl     String?  @map("picture_url") @db.VarChar(500)
  organizationId BigInt?  @map("organization_id")
  roleCode       String?  @map("role_code") @db.VarChar(50)
  status         String   @db.VarChar(30) @default("active")
  createdAt      DateTime @map("created_at") @default(now())
  updatedAt      DateTime @map("updated_at") @updatedAt

  lineChannel          LineChannel               @relation(fields: [lineChannelId], references: [id])
  organization         Organization?             @relation(fields: [organizationId], references: [id])
  user                 User?
  conversationSessions LineConversationSession[]

  @@map("line_users")
}

model LineEvent {
  id             BigInt    @id @default(autoincrement())
  lineChannelId  BigInt    @map("line_channel_id")
  webhookEventId String    @map("webhook_event_id") @db.VarChar(100) @unique
  lineUserId     String    @map("line_user_id") @db.VarChar(100)
  eventType      String    @map("event_type") @db.VarChar(50)
  messageId      String?   @map("message_id") @db.VarChar(100)
  messageType    String?   @map("message_type") @db.VarChar(50)
  replyToken     String?   @map("reply_token") @db.VarChar(255)
  rawPayloadJson String    @map("raw_payload_json") @db.LongText
  isRedelivery   Boolean   @map("is_redelivery") @default(false)
  receiveStatus  String    @map("receive_status") @db.VarChar(30) @default("received")
  receivedAt     DateTime  @map("received_at") @default(now())
  processedAt    DateTime? @map("processed_at")

  lineChannel     LineChannel      @relation(fields: [lineChannelId], references: [id])
  documentIntakes DocumentIntake[]

  @@index([lineUserId])
  @@map("line_events")
}

model DocumentIntake {
  id                  BigInt    @id @default(autoincrement())
  sourceChannel       String    @map("source_channel") @db.VarChar(50)
  lineEventId         BigInt?   @map("line_event_id")
  lineUserIdRef       BigInt?   @map("line_user_id_ref")
  organizationId      BigInt?   @map("organization_id")
  academicYearId      BigInt?   @map("academic_year_id")
  originalFileName    String?   @map("original_file_name") @db.VarChar(255)
  mimeType            String    @map("mime_type") @db.VarChar(100)
  fileExtension       String?   @map("file_extension") @db.VarChar(20)
  fileSize            BigInt?   @map("file_size")
  storagePath         String?   @map("storage_path") @db.VarChar(500)
  sha256              String?   @db.VarChar(64)
  googleDriveFileId   String?   @map("google_drive_file_id") @db.VarChar(255)
  googleDriveFolderId String?   @map("google_drive_folder_id") @db.VarChar(255)
  uploadStatus        String    @map("upload_status") @db.VarChar(30) @default("received")
  ocrStatus           String    @map("ocr_status") @db.VarChar(30) @default("pending")
  classifierStatus    String    @map("classifier_status") @db.VarChar(30) @default("pending")
  aiStatus            String    @map("ai_status") @db.VarChar(30) @default("pending")
  createdAt           DateTime  @map("created_at") @default(now())
  updatedAt           DateTime  @map("updated_at") @updatedAt

  lineEvent            LineEvent?               @relation(fields: [lineEventId], references: [id])
  organization         Organization?            @relation(fields: [organizationId], references: [id])
  academicYear         AcademicYear?            @relation(fields: [academicYearId], references: [id])
  aiResult             DocumentAiResult?
  conversationSessions LineConversationSession[]

  @@index([academicYearId])
  @@map("document_intakes")
}

model DocumentAiResult {
  id                       BigInt    @id @default(autoincrement())
  documentIntakeId         BigInt    @map("document_intake_id") @unique
  isOfficialDocument       Boolean?  @map("is_official_document")
  classificationLabel      String?   @map("classification_label") @db.VarChar(50)
  classificationConfidence Float?    @map("classification_confidence")
  issuingAuthority         String?   @map("issuing_authority") @db.VarChar(255)
  recipientText            String?   @map("recipient_text") @db.VarChar(500)
  documentNo               String?   @map("document_no") @db.VarChar(100)
  documentDate             DateTime? @map("document_date")
  subjectText              String?   @map("subject_text") @db.Text
  summaryText              String?   @map("summary_text") @db.LongText
  extractedText            String?   @map("extracted_text") @db.LongText
  deadlineDate             DateTime? @map("deadline_date")
  isMeeting                Boolean   @map("is_meeting") @default(false)
  meetingDate              DateTime? @map("meeting_date")
  meetingTime              String?   @map("meeting_time") @db.VarChar(20)
  meetingLocation          String?   @map("meeting_location") @db.VarChar(500)
  nextActionJson           String?   @map("next_action_json") @db.LongText
  structuredSummaryJson    String?   @map("structured_summary_json") @db.LongText
  createdAt                DateTime  @map("created_at") @default(now())
  updatedAt                DateTime  @map("updated_at") @updatedAt

  documentIntake DocumentIntake @relation(fields: [documentIntakeId], references: [id])

  @@map("document_ai_results")
}

model LineConversationSession {
  id               BigInt    @id @default(autoincrement())
  lineUserIdRef    BigInt    @map("line_user_id_ref")
  documentIntakeId BigInt?   @map("document_intake_id")
  sessionType      String    @map("session_type") @db.VarChar(50)
  currentStep      String?   @map("current_step") @db.VarChar(100)
  contextJson      String?   @map("context_json") @db.LongText
  status           String    @db.VarChar(30) @default("open")
  expiresAt        DateTime? @map("expires_at")
  createdAt        DateTime  @map("created_at") @default(now())
  updatedAt        DateTime  @map("updated_at") @updatedAt

  lineUser       LineUser        @relation(fields: [lineUserIdRef], references: [id])
  documentIntake DocumentIntake? @relation(fields: [documentIntakeId], references: [id])
  actions        LineSessionAction[]

  @@map("line_conversation_sessions")
}

model LineSessionAction {
  id          BigInt   @id @default(autoincrement())
  sessionId   BigInt   @map("session_id")
  actionCode  String   @map("action_code") @db.VarChar(50)
  actionLabel String   @map("action_label") @db.VarChar(255)
  payloadJson String?  @map("payload_json") @db.LongText
  createdAt   DateTime @map("created_at") @default(now())

  session LineConversationSession @relation(fields: [sessionId], references: [id])

  @@map("line_session_actions")
}

// ─────────────────────────────────────────────
// PHASE 2: Authentication
// ─────────────────────────────────────────────

model User {
  id               BigInt    @id @default(autoincrement())
  email            String    @unique @db.VarChar(255)
  passwordHash     String    @map("password_hash") @db.VarChar(255)
  fullName         String    @map("full_name") @db.VarChar(255)
  roleCode         String    @map("role_code") @db.VarChar(30) // DIRECTOR | VICE_DIRECTOR | HEAD_TEACHER | TEACHER | CLERK | ADMIN
  organizationId   BigInt?   @map("organization_id")
  workGroupId      BigInt?   @map("work_group_id") // primary work group assignment
  positionTitle    String?   @map("position_title") @db.VarChar(255) // "ครูชำนาญการพิเศษ", "ผู้อำนวยการโรงเรียน"
  department       String?   @db.VarChar(100) // academic | budget | personnel | general
  responsibilities String?   @db.Text // free text: "งานสารบรรณ, งานพัสดุ"
  phone            String?   @db.VarChar(20)
  googleEmail      String?   @map("google_email") @db.VarChar(255) // for Calendar invite
  signaturePath    String?   @map("signature_path") @db.VarChar(500) // MinIO path to signature image
  lineUserRef      BigInt?   @map("line_user_ref") @unique // 1:1 link to LineUser
  isActive         Boolean   @map("is_active") @default(true)
  lastLoginAt      DateTime? @map("last_login_at")
  createdAt        DateTime  @map("created_at") @default(now())
  updatedAt        DateTime  @map("updated_at") @updatedAt

  organization          Organization?      @relation(fields: [organizationId], references: [id])
  workGroup             WorkGroup?         @relation(fields: [workGroupId], references: [id])
  lineUser              LineUser?          @relation(fields: [lineUserRef], references: [id])
  pairingCodes          UserPairingCode[]
  registeredCases       InboundCase[]      @relation("CaseRegisteredBy")
  assignedCases         InboundCase[]      @relation("CaseAssignedTo")
  assignmentsGiven      CaseAssignment[]   @relation("AssignmentGivenBy")
  assignmentsReceived   CaseAssignment[]   @relation("AssignmentReceivedBy")
  caseActivities        CaseActivity[]
  staffAssignments      StaffAssignment[]
  outboundApprovals     OutboundDocument[] @relation("OutboundApprovedBy")
  outboundCreated       OutboundDocument[] @relation("OutboundCreatedBy")
  projectsResponsible   Project[]          @relation("ProjectResponsible")
  faceRegistrations     FaceRegistration[]
  attendanceRecords     AttendanceRecord[]
  leaveRequestsMade     LeaveRequest[]     @relation("LeaveRequestUser")
  leaveRequestsApproved LeaveRequest[]     @relation("LeaveApprovedBy")
  leaveCurrentApprovals LeaveRequest[]     @relation("LeaveCurrentApprover")
  leaveStepApprovals    LeaveApprovalStep[] @relation("LeaveStepApprover")
  travelRequestsMade    TravelRequest[]    @relation("TravelRequestUser")
  travelRequestsApproved TravelRequest[]   @relation("TravelApprovedBy")
  leaveBalances         LeaveBalance[]
  knowledgeItems        UserKnowledgeItem[]

  @@index([email])
  @@index([roleCode])
  @@index([organizationId])
  @@index([workGroupId])
  @@map("users")
}

model UserPairingCode {
  id        BigInt    @id @default(autoincrement())
  userId    BigInt    @map("user_id")
  code      String    @db.VarChar(10) @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  usedByLineUserId BigInt? @map("used_by_line_user_id")
  createdAt DateTime  @map("created_at") @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([code])
  @@map("user_pairing_codes")
}

// ─────────────────────────────────────────────
// PHASE 3: Multi-Year, Multi-School
// ─────────────────────────────────────────────

model AcademicYear {
  id        BigInt   @id @default(autoincrement())
  year      Int      @unique // พ.ศ. เช่น 2567
  name      String   @db.VarChar(100) // "ปีการศึกษา 2567"
  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")
  isCurrent Boolean  @map("is_current") @default(false)
  createdAt DateTime @map("created_at") @default(now())

  cases              InboundCase[]
  intakes            DocumentIntake[]
  budgets            Budget[]
  staffAssignments   StaffAssignment[]
  documentRegistries DocumentRegistry[]
  leaveBalances      LeaveBalance[]
  activeOrganizations Organization[] @relation("OrgActiveYear")

  @@map("academic_years")
}

model Budget {
  id               BigInt   @id @default(autoincrement())
  organizationId   BigInt   @map("organization_id")
  academicYearId   BigInt   @map("academic_year_id")
  budgetType       String   @map("budget_type") @db.VarChar(100) // "งบดำเนินงาน" | "งบลงทุน" | "งบอุดหนุน"
  allocatedAmount  Decimal  @map("allocated_amount") @db.Decimal(15, 2)
  usedAmount       Decimal  @map("used_amount") @db.Decimal(15, 2) @default(0)
  note             String?  @db.Text
  createdAt        DateTime @map("created_at") @default(now())
  updatedAt        DateTime @map("updated_at") @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([organizationId, academicYearId, budgetType])
  @@map("budgets")
}

// ─────────────────────────────────────────────
// PHASE 4: Workflow — Assignment & Activity
// ─────────────────────────────────────────────

model CaseAssignment {
  id                    BigInt    @id @default(autoincrement())
  inboundCaseId         BigInt    @map("inbound_case_id")
  assignedToUserId      BigInt    @map("assigned_to_user_id")
  assignedByUserId      BigInt    @map("assigned_by_user_id")
  role                  String    @db.VarChar(30) @default("responsible") // responsible | informed | cc
  dueDate               DateTime? @map("due_date")
  status                String    @db.VarChar(30) @default("pending") // pending → accepted → in_progress → completed
  note                  String?   @db.Text
  completedAt           DateTime? @map("completed_at")
  googleCalendarEventId String?   @map("google_calendar_event_id") @db.VarChar(255)
  createdAt             DateTime  @map("created_at") @default(now())
  updatedAt             DateTime  @map("updated_at") @updatedAt

  inboundCase  InboundCase @relation(fields: [inboundCaseId], references: [id])
  assignedTo   User        @relation("AssignmentReceivedBy", fields: [assignedToUserId], references: [id])
  assignedBy   User        @relation("AssignmentGivenBy", fields: [assignedByUserId], references: [id])

  @@index([inboundCaseId])
  @@index([assignedToUserId])
  @@index([status])
  @@map("case_assignments")
}

model CaseActivity {
  id            BigInt   @id @default(autoincrement())
  inboundCaseId BigInt   @map("inbound_case_id")
  userId        BigInt?  @map("user_id")
  action        String   @db.VarChar(50) // register | assign | comment | update_status | select_option | complete | close
  detail        String?  @db.LongText // JSON payload
  createdAt     DateTime @map("created_at") @default(now())

  inboundCase InboundCase @relation(fields: [inboundCaseId], references: [id])
  user        User?       @relation(fields: [userId], references: [id])

  @@index([inboundCaseId])
  @@index([userId])
  @@map("case_activities")
}

model DocumentRouting {
  id                  BigInt   @id @default(autoincrement())
  documentId          BigInt?  @map("document_id")
  documentIntakeId    BigInt?  @map("document_intake_id")
  fromOrganizationId  BigInt   @map("from_organization_id")
  toOrganizationId    BigInt   @map("to_organization_id")
  routedByUserId      BigInt?  @map("routed_by_user_id")
  action              String   @db.VarChar(30) // forward | assign | cc | return
  note                String?  @db.Text
  routedAt            DateTime @map("routed_at") @default(now())

  fromOrganization Organization @relation("RoutingFrom", fields: [fromOrganizationId], references: [id])
  toOrganization   Organization @relation("RoutingTo", fields: [toOrganizationId], references: [id])

  @@index([fromOrganizationId])
  @@index([toOrganizationId])
  @@map("document_routings")
}

// ─────────────────────────────────────────────
// PHASE C: โครงสร้างองค์กร + กลุ่มงาน
// ─────────────────────────────────────────────

model WorkGroup {
  id             BigInt   @id @default(autoincrement())
  organizationId BigInt?  @map("organization_id") // null = shared template ทุกโรงเรียน
  code           String   @db.VarChar(30)         // academic | budget | personnel | general
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  sortOrder      Int      @map("sort_order") @default(0)
  isActive       Boolean  @map("is_active") @default(true)
  createdAt      DateTime @map("created_at") @default(now())

  organization  Organization?    @relation(fields: [organizationId], references: [id])
  functions     WorkFunction[]
  staffMembers  User[]           // users whose primary group = this WorkGroup

  @@unique([organizationId, code])
  @@map("work_groups")
}

model WorkFunction {
  id           BigInt   @id @default(autoincrement())
  workGroupId  BigInt   @map("work_group_id")
  code         String   @db.VarChar(50)
  name         String   @db.VarChar(500)
  description  String?  @db.Text
  sortOrder    Int      @map("sort_order") @default(0)
  isActive     Boolean  @map("is_active") @default(true)
  createdAt    DateTime @map("created_at") @default(now())

  workGroup   WorkGroup        @relation(fields: [workGroupId], references: [id])
  assignments StaffAssignment[]

  @@unique([workGroupId, code])
  @@map("work_functions")
}

model StaffAssignment {
  id               BigInt   @id @default(autoincrement())
  organizationId   BigInt   @map("organization_id")
  userId           BigInt   @map("user_id")
  workFunctionId   BigInt   @map("work_function_id")
  role             String   @db.VarChar(20) @default("responsible") // head | responsible | assistant
  academicYearId   BigInt   @map("academic_year_id")
  semester         Int      @default(0)                              // 0=ทั้งปี 1=ภาค1 2=ภาค2
  appointmentOrderNo String? @map("appointment_order_no") @db.VarChar(50)
  effectiveDate    DateTime? @map("effective_date")
  note             String?  @db.Text
  isActive         Boolean  @map("is_active") @default(true)
  createdAt        DateTime @map("created_at") @default(now())
  updatedAt        DateTime @map("updated_at") @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  workFunction   WorkFunction @relation(fields: [workFunctionId], references: [id])
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@index([organizationId, academicYearId])
  @@index([userId])
  @@map("staff_assignments")
}

// ─────────────────────────────────────────────
// PHASE D: หนังสือส่ง + ทะเบียนครบวงจร
// ─────────────────────────────────────────────

model OutboundDocument {
  id                  BigInt    @id @default(autoincrement())
  organizationId      BigInt    @map("organization_id")
  documentNo          String?   @map("document_no") @db.VarChar(100)   // เลขที่หนังสือส่ง
  documentDate        DateTime? @map("document_date")
  recipientName       String?   @map("recipient_name") @db.VarChar(255)
  recipientOrg        String?   @map("recipient_org") @db.VarChar(255)
  recipientEmail      String?   @map("recipient_email") @db.VarChar(255)
  subject             String    @db.VarChar(500)
  bodyText            String?   @map("body_text") @db.LongText
  urgencyLevel        String    @map("urgency_level") @db.VarChar(20) @default("normal") // normal | urgent | very_urgent | most_urgent
  securityLevel       String    @map("security_level") @db.VarChar(20) @default("normal") // normal | confidential | secret
  status              String    @db.VarChar(30) @default("draft")     // draft | pending_approval | approved | sent
  relatedInboundCaseId BigInt?  @map("related_inbound_case_id")
  approvedByUserId    BigInt?   @map("approved_by_user_id")
  approvedAt          DateTime? @map("approved_at")
  sentAt              DateTime? @map("sent_at")
  sentMethod          String?   @map("sent_method") @db.VarChar(30)   // email | line | paper
  storagePath         String?   @map("storage_path") @db.VarChar(500)
  createdByUserId     BigInt?   @map("created_by_user_id")
  createdAt           DateTime  @map("created_at") @default(now())
  updatedAt           DateTime  @map("updated_at") @updatedAt

  organization       Organization       @relation(fields: [organizationId], references: [id])
  relatedInboundCase InboundCase?       @relation(fields: [relatedInboundCaseId], references: [id])
  approvedBy         User?              @relation("OutboundApprovedBy", fields: [approvedByUserId], references: [id])
  createdBy          User?              @relation("OutboundCreatedBy", fields: [createdByUserId], references: [id])
  documentRegistries DocumentRegistry[]

  @@index([organizationId, status])
  @@index([documentNo])
  @@map("outbound_documents")
}

model DocumentRegistry {
  id             BigInt   @id @default(autoincrement())
  organizationId BigInt   @map("organization_id")
  registryType   String   @map("registry_type") @db.VarChar(20)   // inbound | outbound | archive | destroy
  registryNo     String?  @map("registry_no") @db.VarChar(20)     // ลำดับทะเบียน
  documentNo     String?  @map("document_no") @db.VarChar(100)    // เลขที่หนังสือ
  documentDate   DateTime? @map("document_date")
  fromOrg        String?  @map("from_org") @db.VarChar(255)
  toOrg          String?  @map("to_org") @db.VarChar(255)
  subject        String?  @db.VarChar(500)
  urgencyLevel   String?  @map("urgency_level") @db.VarChar(20)
  actionTaken    String?  @map("action_taken") @db.Text
  remarks        String?  @db.Text
  inboundCaseId  BigInt?  @map("inbound_case_id")
  outboundDocId  BigInt?  @map("outbound_doc_id")
  academicYearId BigInt?  @map("academic_year_id")
  createdAt      DateTime @map("created_at") @default(now())

  organization   Organization      @relation(fields: [organizationId], references: [id])
  inboundCase    InboundCase?      @relation(fields: [inboundCaseId], references: [id])
  outboundDoc    OutboundDocument? @relation(fields: [outboundDocId], references: [id])
  academicYear   AcademicYear?     @relation(fields: [academicYearId], references: [id])

  @@index([organizationId, registryType])
  @@index([academicYearId])
  @@map("document_registries")
}

model RegistrationCounter {
  id             BigInt   @id @default(autoincrement())
  organizationId BigInt   @map("organization_id")
  year           Int      // ค.ศ. (Gregorian) — used as key only; display uses พ.ศ.
  lastSeq        Int      @map("last_seq") @default(0)
  updatedAt      DateTime @map("updated_at") @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, year])
  @@map("registration_counters")
}

// ─────────────────────────────────────────────
// PHASE V2: Predictive Workflow
// ─────────────────────────────────────────────

model CasePrediction {
  id              BigInt    @id @default(autoincrement())
  inboundCaseId   BigInt    @map("inbound_case_id")
  predictionType  String    @map("prediction_type") @db.VarChar(50)   // deadline, risk, next_step, assignee, routing
  predictionValue String    @map("prediction_value") @db.Text         // JSON with prediction details
  confidence      Decimal   @db.Decimal(5, 4)
  isAccepted      Boolean?  @map("is_accepted")                       // null = pending, true = accepted, false = rejected
  createdAt       DateTime  @map("created_at") @default(now())
  updatedAt       DateTime  @map("updated_at") @updatedAt

  inboundCase InboundCase @relation(fields: [inboundCaseId], references: [id])

  @@index([inboundCaseId])
  @@map("case_predictions")
}

// ─────────────────────────────────────────────
// PHASE F: System Configuration
// ─────────────────────────────────────────────

model SystemPrompt {
  id          Int      @id @default(autoincrement())
  promptKey   String   @unique @map("prompt_key") @db.VarChar(80)  // e.g. "ocr.pdf", "action.summarize"
  groupName   String   @map("group_name") @db.VarChar(60)          // e.g. "OCR", "AI Actions"
  label       String   @db.VarChar(120)                            // ชื่อแสดงผล
  description String?  @db.Text                                    // คำอธิบาย
  promptText  String   @map("prompt_text") @db.LongText            // เนื้อหา prompt
  temperature Float    @default(0.3)
  maxTokens   Int      @map("max_tokens") @default(1024)
  isActive    Boolean  @map("is_active") @default(true)
  updatedBy   String?  @map("updated_by") @db.VarChar(100)
  createdAt   DateTime @map("created_at") @default(now())
  updatedAt   DateTime @map("updated_at") @updatedAt

  @@map("system_prompts")
}

// ─────────────────────────────────────────────
// PHASE E: Vector Embeddings
// ─────────────────────────────────────────────

model KnowledgeEmbedding {
  id             BigInt   @id @default(autoincrement())
  sourceType     String   @map("source_type") @db.VarChar(30)   // policy_clause | horizon_practice | document_chunk
  sourceId       BigInt   @map("source_id")
  qdrantPointId  String   @map("qdrant_point_id") @db.VarChar(36) // UUID in Qdrant
  collection     String   @db.VarChar(50)                         // knowledge | documents
  embeddingModel String   @map("embedding_model") @db.VarChar(50) // text-embedding-004
  tokenCount     Int?     @map("token_count")
  embeddedAt     DateTime @map("embedded_at") @default(now())

  @@index([sourceType, sourceId])
  @@index([qdrantPointId])
  @@map("knowledge_embeddings")
}

// ─────────────────────────────────────────────
// PHASE 2: Horizon Intelligence System
// ─────────────────────────────────────────────

model HorizonSource {
  id               BigInt    @id @default(autoincrement())
  sourceCode       String    @unique @map("source_code") @db.VarChar(50)
  sourceName       String    @map("source_name") @db.VarChar(255)
  sourceType       String    @map("source_type") @db.VarChar(50)   // website, rss, api, manual
  organizationName String    @map("organization_name") @db.VarChar(255) // สพฐ., ศธ.
  baseUrl          String    @map("base_url") @db.Text
  trustLevel       Decimal   @map("trust_level") @db.Decimal(3, 2) @default(0.80)
  fetchFrequency   String    @map("fetch_frequency") @db.VarChar(30) @default("daily")
  configJson       String?   @map("config_json") @db.Text
  isActive         Boolean   @map("is_active") @default(true)
  lastFetchAt      DateTime? @map("last_fetch_at")
  createdAt        DateTime  @map("created_at") @default(now())
  updatedAt        DateTime  @map("updated_at") @updatedAt

  documents HorizonSourceDocument[]

  @@map("horizon_sources")
}

model HorizonSourceDocument {
  id              BigInt    @id @default(autoincrement())
  sourceId        BigInt    @map("source_id")
  externalId      String?   @map("external_id") @db.VarChar(255)
  title           String    @db.Text
  url             String    @db.Text
  contentType     String    @map("content_type") @db.VarChar(50)  // news, policy_news, event, announcement, speech, report
  publishedAt     DateTime? @map("published_at")
  fetchedAt       DateTime  @map("fetched_at") @default(now())
  rawText         String    @map("raw_text") @db.LongText
  normalizedText  String?   @map("normalized_text") @db.LongText
  summaryText     String?   @map("summary_text") @db.LongText
  contentHash     String    @map("content_hash") @db.VarChar(128)
  qualityScore    Decimal?  @map("quality_score") @db.Decimal(5, 4)
  status          String    @db.VarChar(30) @default("fetched")   // fetched, normalized, classified, embedded
  createdAt       DateTime  @map("created_at") @default(now())
  updatedAt       DateTime  @map("updated_at") @updatedAt

  source  HorizonSource           @relation(fields: [sourceId], references: [id])
  agendas HorizonDocumentAgenda[]
  signals HorizonSignal[]
  chunks  HorizonChunk[]

  @@unique([sourceId, contentHash])
  @@index([status])
  @@index([contentType])
  @@map("horizon_source_documents")
}

model HorizonAgenda {
  id              BigInt    @id @default(autoincrement())
  agendaCode      String    @unique @map("agenda_code") @db.VarChar(100)
  agendaTitle     String    @map("agenda_title") @db.VarChar(255)
  agendaType      String    @map("agenda_type") @db.VarChar(50)   // policy_push, campaign, event_series, reform_signal, operational_focus
  agendaScope     String    @map("agenda_scope") @db.VarChar(50)  // national, regional, district
  leadOrg         String?   @map("lead_org") @db.VarChar(255)
  currentStatus   String    @map("current_status") @db.VarChar(50) @default("emerging") // emerging, active, peak, fading, closed
  priorityScore   Decimal?  @map("priority_score") @db.Decimal(5, 4)
  momentumScore   Decimal?  @map("momentum_score") @db.Decimal(5, 4)
  summaryText     String?   @map("summary_text") @db.LongText
  topicTags       String?   @map("topic_tags") @db.Text           // JSON array of topic codes
  startDate       DateTime? @map("start_date") @db.Date
  endDate         DateTime? @map("end_date") @db.Date
  createdAt       DateTime  @map("created_at") @default(now())
  updatedAt       DateTime  @map("updated_at") @updatedAt

  documents       HorizonDocumentAgenda[]
  recommendations HorizonRecommendationPattern[]

  @@index([currentStatus])
  @@index([agendaType])
  @@map("horizon_agendas")
}

model HorizonDocumentAgenda {
  id                BigInt   @id @default(autoincrement())
  horizonDocumentId BigInt   @map("horizon_document_id")
  horizonAgendaId   BigInt   @map("horizon_agenda_id")
  relationType      String   @map("relation_type") @db.VarChar(50) // primary, secondary, mention
  confidenceScore   Decimal  @map("confidence_score") @db.Decimal(5, 4)
  createdAt         DateTime @map("created_at") @default(now())

  document HorizonSourceDocument @relation(fields: [horizonDocumentId], references: [id])
  agenda   HorizonAgenda         @relation(fields: [horizonAgendaId], references: [id])

  @@index([horizonDocumentId])
  @@index([horizonAgendaId])
  @@map("horizon_document_agendas")
}

model HorizonSignal {
  id                 BigInt    @id @default(autoincrement())
  horizonDocumentId  BigInt    @map("horizon_document_id")
  signalType         String    @map("signal_type") @db.VarChar(50)  // policy_signal, event_signal, urgency_signal, funding_signal, implementation_signal
  signalTitle        String    @map("signal_title") @db.VarChar(255)
  signalText         String    @map("signal_text") @db.LongText
  actionabilityLevel String    @map("actionability_level") @db.VarChar(30) // low, medium, high
  targetEntities     String?   @map("target_entities") @db.VarChar(255)
  effectiveDate      DateTime? @map("effective_date") @db.Date
  expiresAt          DateTime? @map("expires_at") @db.Date
  createdAt          DateTime  @map("created_at") @default(now())

  document HorizonSourceDocument @relation(fields: [horizonDocumentId], references: [id])

  @@index([horizonDocumentId])
  @@index([signalType])
  @@map("horizon_signals")
}

model HorizonChunk {
  id                BigInt    @id @default(autoincrement())
  horizonDocumentId BigInt    @map("horizon_document_id")
  chunkIndex        Int       @map("chunk_index")
  chunkText         String    @map("chunk_text") @db.LongText
  sectionLabel      String?   @map("section_label") @db.VarChar(100) // title, summary, body, agenda_signal
  tokenCount        Int?      @map("token_count")
  qdrantPointId     String?   @map("qdrant_point_id") @db.VarChar(100)
  embeddedAt        DateTime? @map("embedded_at")
  createdAt         DateTime  @map("created_at") @default(now())

  document HorizonSourceDocument @relation(fields: [horizonDocumentId], references: [id])

  @@index([horizonDocumentId])
  @@map("horizon_chunks")
}

model HorizonRecommendationPattern {
  id                  BigInt   @id @default(autoincrement())
  horizonAgendaId     BigInt   @map("horizon_agenda_id")
  contextProfileCode  String   @map("context_profile_code") @db.VarChar(100) // remote_low_budget, urban_large_school
  recommendationTitle String   @map("recommendation_title") @db.VarChar(255)
  recommendationText  String   @map("recommendation_text") @db.LongText
  feasibilityNote     String?  @map("feasibility_note") @db.Text
  riskNote            String?  @map("risk_note") @db.Text
  createdAt           DateTime @map("created_at") @default(now())
  updatedAt           DateTime @map("updated_at") @updatedAt

  agenda HorizonAgenda @relation(fields: [horizonAgendaId], references: [id])

  @@index([horizonAgendaId])
  @@map("horizon_recommendation_patterns")
}

// ─────────────────────────────────────────────
// PHASE 2: Project Memory Engine
// ─────────────────────────────────────────────

model Project {
  id                BigInt    @id @default(autoincrement())
  organizationId    BigInt    @map("organization_id")
  name              String    @db.VarChar(255)
  description       String?   @db.Text
  status            String    @db.VarChar(50) @default("draft") // draft, active, completed, archived
  startDate         DateTime? @map("start_date") @db.Date
  endDate           DateTime? @map("end_date") @db.Date
  budgetAmount      Decimal?  @map("budget_amount") @db.Decimal(12, 2)
  responsibleUserId BigInt?   @map("responsible_user_id")
  policyAlignment   String?   @map("policy_alignment") @db.Text // JSON: aligned agenda codes
  createdAt         DateTime  @map("created_at") @default(now())
  updatedAt         DateTime  @map("updated_at") @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  responsible  User?          @relation("ProjectResponsible", fields: [responsibleUserId], references: [id])
  topics       ProjectTopic[]
  documents    ProjectDocument[]
  reports      ProjectReport[]

  @@index([organizationId])
  @@index([status])
  @@map("projects")
}

model ProjectTopic {
  id        BigInt   @id @default(autoincrement())
  projectId BigInt   @map("project_id")
  topicCode String   @map("topic_code") @db.VarChar(100)
  score     Decimal? @db.Decimal(5, 4)

  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, topicCode])
  @@map("project_topics")
}

model ProjectDocument {
  id             BigInt   @id @default(autoincrement())
  projectId      BigInt   @map("project_id")
  inboundCaseId  BigInt?  @map("inbound_case_id")
  documentId     BigInt?  @map("document_id")
  linkType       String   @map("link_type") @db.VarChar(30) // auto_matched, manual
  matchScore     Decimal? @map("match_score") @db.Decimal(5, 4)
  matchRationale String?  @map("match_rationale") @db.Text
  createdAt      DateTime @map("created_at") @default(now())

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([inboundCaseId])
  @@map("project_documents")
}

model ProjectReport {
  id         BigInt   @id @default(autoincrement())
  projectId  BigInt   @map("project_id")
  reportType String   @map("report_type") @db.VarChar(50)  // progress, final, evaluation
  period     String?  @db.VarChar(50) // Q1-2026, annual-2026
  content    String?  @db.LongText
  status     String   @db.VarChar(30) @default("draft")    // draft, submitted, approved
  createdAt  DateTime @map("created_at") @default(now())
  updatedAt  DateTime @map("updated_at") @updatedAt

  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@map("project_reports")
}

// ─────────────────────────────────────────────
// PHASE 2: Adaptive Workflow Learning
// ─────────────────────────────────────────────

model WorkflowPattern {
  id              BigInt   @id @default(autoincrement())
  organizationId  BigInt   @map("organization_id")
  documentType    String   @map("document_type") @db.VarChar(50)
  topicCode       String   @map("topic_code") @db.VarChar(100)
  routedToGroup   String?  @map("routed_to_group") @db.VarChar(100)
  assignedToRole  String?  @map("assigned_to_role") @db.VarChar(100)
  avgProcessDays  Decimal? @map("avg_process_days") @db.Decimal(6, 2)
  sampleCount     Int      @map("sample_count") @default(1)
  createdAt       DateTime @map("created_at") @default(now())
  updatedAt       DateTime @map("updated_at") @updatedAt

  @@unique([organizationId, documentType, topicCode])
  @@index([organizationId])
  @@map("workflow_patterns")
}

// ─────────────────────────────────────────────
// PHASE 3: Knowledge Vault
// ─────────────────────────────────────────────

model KnowledgeNote {
  id              BigInt    @id @default(autoincrement())
  organizationId  BigInt?   @map("organization_id")
  noteType        String    @map("note_type") @db.VarChar(50)   // policy, letter, project, report, agenda
  title           String    @db.VarChar(255)
  contentMd       String    @map("content_md") @db.LongText     // Markdown content
  frontmatterJson String?   @map("frontmatter_json") @db.Text   // YAML frontmatter as JSON
  folderPath      String?   @map("folder_path") @db.VarChar(255) // e.g. 01_Policies/
  status          String    @db.VarChar(30) @default("ai_draft") // ai_draft, reviewed, published, archived
  sourceType      String?   @map("source_type") @db.VarChar(50) // inbound_case, horizon_document, project, horizon_agenda
  sourceId        BigInt?   @map("source_id")
  linkedNotes     String?   @map("linked_notes") @db.Text       // JSON: [{noteId, relation, title}]
  confidence      Decimal?  @db.Decimal(5, 4)
  syncedAt        DateTime? @map("synced_at")
  createdAt       DateTime  @map("created_at") @default(now())
  updatedAt       DateTime  @map("updated_at") @updatedAt

  @@index([organizationId])
  @@index([noteType])
  @@index([status])
  @@index([sourceType, sourceId])
  @@map("knowledge_notes")
}

model KnowledgeVaultConfig {
  id              BigInt    @id @default(autoincrement())
  organizationId  BigInt    @unique @map("organization_id")
  vaultPath       String    @map("vault_path") @db.VarChar(500)
  syncEnabled     Boolean   @map("sync_enabled") @default(false)
  autoGenerate    Boolean   @map("auto_generate") @default(true)
  lastSyncAt      DateTime? @map("last_sync_at")
  configJson      String?   @map("config_json") @db.Text        // JSON: folder mapping, template overrides
  createdAt       DateTime  @map("created_at") @default(now())
  updatedAt       DateTime  @map("updated_at") @updatedAt

  @@map("knowledge_vault_configs")
}

// ─────────────────────────────────────────────
// PHASE 4: Attendance / Leave / Travel
// ─────────────────────────────────────────────

model FaceRegistration {
  id              BigInt    @id @default(autoincrement())
  userId          BigInt    @map("user_id")
  organizationId  BigInt    @map("organization_id")
  faceImagePath   String    @map("face_image_path") @db.VarChar(500) // MinIO path
  faceEncodingId  String?   @map("face_encoding_id") @db.VarChar(100) // ID in Python Face Service
  status          String    @db.VarChar(30) @default("pending") // pending | active | revoked
  registeredAt    DateTime  @map("registered_at") @default(now())
  revokedAt       DateTime? @map("revoked_at")
  createdAt       DateTime  @map("created_at") @default(now())
  updatedAt       DateTime  @map("updated_at") @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@map("face_registrations")
}

model AttendanceRecord {
  id                BigInt    @id @default(autoincrement())
  userId            BigInt    @map("user_id")
  organizationId    BigInt    @map("organization_id")
  attendanceDate    DateTime  @map("attendance_date") @db.Date
  checkInAt         DateTime? @map("check_in_at")
  checkOutAt        DateTime? @map("check_out_at")
  checkInLatitude   Float?    @map("check_in_latitude")
  checkInLongitude  Float?    @map("check_in_longitude")
  checkOutLatitude  Float?    @map("check_out_latitude")
  checkOutLongitude Float?    @map("check_out_longitude")
  checkInImagePath  String?   @map("check_in_image_path") @db.VarChar(500)
  checkOutImagePath String?   @map("check_out_image_path") @db.VarChar(500)
  faceMatchScore    Float?    @map("face_match_score")
  geofenceValid     Boolean   @map("geofence_valid") @default(true)
  status            String    @db.VarChar(30) @default("checked_in")
  // status: checked_in | checked_out | absent | leave | travel | late
  remark            String?   @db.Text
  createdAt         DateTime  @map("created_at") @default(now())
  updatedAt         DateTime  @map("updated_at") @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, attendanceDate])
  @@index([organizationId, attendanceDate])
  @@map("attendance_records")
}

model LeaveRequest {
  id                    BigInt    @id @default(autoincrement())
  userId                BigInt    @map("user_id")
  organizationId        BigInt    @map("organization_id")
  leaveType             String    @map("leave_type") @db.VarChar(30)
  // leaveType: sick | personal | vacation | maternity | ordination | training
  startDate             DateTime  @map("start_date") @db.Date
  endDate               DateTime  @map("end_date") @db.Date
  totalDays             Decimal   @map("total_days") @db.Decimal(5, 1)
  reason                String?   @db.Text
  contactPhone          String?   @map("contact_phone") @db.VarChar(20)
  attachmentPath        String?   @map("attachment_path") @db.VarChar(500)
  status                String    @db.VarChar(30) @default("draft")
  // status: draft | pending | approved | rejected | cancelled
  currentApproverUserId BigInt?   @map("current_approver_user_id")
  approvedByUserId      BigInt?   @map("approved_by_user_id")
  approvedAt            DateTime? @map("approved_at")
  rejectedReason        String?   @map("rejected_reason") @db.Text
  submittedAt           DateTime? @map("submitted_at")
  createdAt             DateTime  @map("created_at") @default(now())
  updatedAt             DateTime  @map("updated_at") @updatedAt

  user            User               @relation("LeaveRequestUser", fields: [userId], references: [id])
  organization    Organization       @relation(fields: [organizationId], references: [id])
  currentApprover User?              @relation("LeaveCurrentApprover", fields: [currentApproverUserId], references: [id])
  approvedBy      User?              @relation("LeaveApprovedBy", fields: [approvedByUserId], references: [id])
  approvalSteps   LeaveApprovalStep[]

  @@index([userId, status])
  @@index([organizationId, status])
  @@map("leave_requests")
}

model LeaveApprovalStep {
  id             BigInt    @id @default(autoincrement())
  leaveRequestId BigInt    @map("leave_request_id")
  stepOrder      Int       @map("step_order")
  approverUserId BigInt    @map("approver_user_id")
  approverRole   String    @map("approver_role") @db.VarChar(30)
  status         String    @db.VarChar(30) @default("pending")
  // status: pending | approved | rejected
  comment        String?   @db.Text
  actedAt        DateTime? @map("acted_at")
  createdAt      DateTime  @map("created_at") @default(now())

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id])
  approver     User         @relation("LeaveStepApprover", fields: [approverUserId], references: [id])

  @@index([leaveRequestId])
  @@map("leave_approval_steps")
}

model TravelRequest {
  id               BigInt    @id @default(autoincrement())
  userId           BigInt    @map("user_id")
  organizationId   BigInt    @map("organization_id")
  travelDate       DateTime  @map("travel_date") @db.Date
  destination      String    @db.VarChar(500)
  purpose          String    @db.Text
  departureTime    String?   @map("departure_time") @db.VarChar(10) // HH:mm
  returnTime       String?   @map("return_time") @db.VarChar(10)
  returnSameDay    Boolean   @map("return_same_day") @default(true)
  status           String    @db.VarChar(30) @default("draft")
  // status: draft | pending | approved | rejected | cancelled
  approvedByUserId BigInt?   @map("approved_by_user_id")
  approvedAt       DateTime? @map("approved_at")
  rejectedReason   String?   @map("rejected_reason") @db.Text
  submittedAt      DateTime? @map("submitted_at")
  createdAt        DateTime  @map("created_at") @default(now())
  updatedAt        DateTime  @map("updated_at") @updatedAt

  user         User         @relation("TravelRequestUser", fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
  approvedBy   User?        @relation("TravelApprovedBy", fields: [approvedByUserId], references: [id])

  @@index([userId, status])
  @@index([organizationId, travelDate])
  @@map("travel_requests")
}

model LeaveBalance {
  id             BigInt   @id @default(autoincrement())
  userId         BigInt   @map("user_id")
  academicYearId BigInt   @map("academic_year_id")
  leaveType      String   @map("leave_type") @db.VarChar(30) // sick | personal | vacation
  totalAllowed   Decimal  @map("total_allowed") @db.Decimal(5, 1)
  totalUsed      Decimal  @map("total_used") @db.Decimal(5, 1) @default(0)
  createdAt      DateTime @map("created_at") @default(now())
  updatedAt      DateTime @map("updated_at") @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([userId, academicYearId, leaveType])
  @@map("leave_balances")
}

model ApprovalChainConfig {
  id             BigInt   @id @default(autoincrement())
  organizationId BigInt   @map("organization_id")
  requestType    String   @map("request_type") @db.VarChar(30) // leave | travel
  requesterRole  String   @map("requester_role") @db.VarChar(30) // TEACHER, HEAD_TEACHER, etc.
  stepOrder      Int      @map("step_order")
  approverRole   String   @map("approver_role") @db.VarChar(30) // HEAD_TEACHER, VICE_DIRECTOR, DIRECTOR
  isActive       Boolean  @map("is_active") @default(true)
  createdAt      DateTime @map("created_at") @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, requestType, requesterRole, stepOrder])
  @@map("approval_chain_configs")
}

// ─────────────────────────────────────────────
// User-contributed Knowledge Items
// ─────────────────────────────────────────────

model UserKnowledgeItem {
  id               BigInt    @id @default(autoincrement())
  organizationId   BigInt    @map("organization_id")
  uploadedByUserId BigInt    @map("uploaded_by_user_id")
  title            String    @db.VarChar(500)
  category         String?   @db.VarChar(100)
  description      String?   @db.Text
  sourceType       String    @map("source_type") @db.VarChar(20) // pdf | image | text
  storagePath      String?   @map("storage_path") @db.VarChar(500)
  mimeType         String?   @map("mime_type") @db.VarChar(100)
  status           String    @db.VarChar(20) @default("PENDING") // PENDING | PROCESSING | DONE | ERROR
  extractedText    String?   @map("extracted_text") @db.LongText
  chunkCount       Int       @map("chunk_count") @default(0)
  embeddedAt       DateTime? @map("embedded_at")
  createdAt        DateTime  @map("created_at") @default(now())
  updatedAt        DateTime  @map("updated_at") @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  uploadedBy   User         @relation(fields: [uploadedByUserId], references: [id])

  @@index([organizationId, status])
  @@index([uploadedByUserId])
  @@map("user_knowledge_items")
}
